# Optional: override the extraction model without a redeploy.
# Express mode supports gemini-2.5-flash / -pro / -flash-lite (default: gemini-2.5-flash)

# === Google Workspace OAuth (create at console.cloud.google.com) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Recall.ai ===
RECALL_API_KEY=
RECALL_WEBHOOK_SECRET=
# Recall region (shown in your Recall dashboard URL): us-east-1 | us-west-2 | eu-central-1 | ap-northeast-1
